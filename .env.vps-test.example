APP_ENV=staging
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

POSTGRES_DB=agente_barbearia
POSTGRES_USER=agente_barbearia_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://agente_barbearia_user:CHANGE_ME@postgres:5432/agente_barbearia

BARBERSHOP_INSTANCE=o-original-barbershop
DEFAULT_RESOURCE_KEY=main

EVOLUTION_API_BASE_URL=https://URL-DA-EVOLUTION-NA-VPS
EVOLUTION_API_KEY=CHANGE_ME

OPENAI_API_KEY=CHANGE_ME
OPENAI_BASE_URL=
OPENAI_COMPAT_MODE=responses
OPENAI_MODEL=gpt-4o-mini

LLM_PROVIDER=ollama_cloud
OLLAMA_API_KEY=CHANGE_ME
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_TIMEOUT_SECONDS=120

INBOUND_HANDLER_MODE=logging
INBOUND_ALLOWED_PHONES=55SEUNUMERO

INBOUND_AUDIO_TRANSCRIPTION_ENABLED=false
INBOUND_IMAGE_ANALYSIS_ENABLED=false

ADMIN_DASHBOARD_ENABLED=true
ADMIN_DASHBOARD_USERNAME=admin
ADMIN_DASHBOARD_PASSWORD=CHANGE_ME
